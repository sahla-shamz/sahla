<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_sale.ControlButtons" t-inherit="point_of_sale.ControlButtons" t-inherit-mode="extension">
        <xpath
            expr="//t[@t-if='props.showRemainingButtons']/div/button[hasclass('o_pricelist_button')]"
            position="after">
            <button t-att-class="buttonClass" t-on-click="onClickCreateSaleOrder"
                    t-if="this.pos.config.is_create_sale_order">
                <i class="fa fa-link me-1" role="img" aria-label="Create Sale Order"
                   title="Create Sale Order" /> Create Sale Order
            </button>
        </xpath>
    </t>
</templates>
