<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="organization_chart_form_inheirt" model="ir.ui.view">
        <field name="name">customer.chart.inherit.form.view</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='category_id']" position="after">

               <field name="parent_partner_id" invisible="is_parent"/>
                <field name="is_child"/>

                <field name="is_parent"/>
                <field name="customer_child_ids" widget="custom_org_chart"/>


            </xpath>
        </field>
    </record>

</odoo>