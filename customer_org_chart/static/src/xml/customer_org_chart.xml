<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

<t t-name="customer_org_chart.contact_org_chart">

    <div class="o_org_chart_group_up position-relative">

            <t t-call="customer_org_chart.contact_orgchart_emp_popover">
            </t>

    </div>

</t>

<t t-name="customer_org_chart.contact_orgchart_emp_popover">
    <div class="o_org_chart_popup" role="tooltip">
        <div class="tooltip-arrow"/>
        <h3 class="popover-header">
            <div class="d-flex align-items-center">

                <span class="o_media_object flex-shrink-0 rounded me-1"
                      t-att-style='"background-image:url(\"/web/image/res.partner/"
                      + this.managers.id + "/avatar_1024/?unique=" + this.managers.write_date + "\")"'/>
                    <a href="#" class="o_employee_redirect btn btn-link"
                       t-on-click.prevent="() => this._onEmployeeRedirect(this.managers.id)">
                        <h4 class="flex-grow-1 fw-large"><t t-esc="this.managers.name"/></h4>
                    </a>
                <small class="o_employee_job text-muted" t-attf-class="opacity-100-hover">Parent</small>

            </div>
            <t t-foreach="children" t-as="child" t-key="child_index">

                <div class="d-flex w-100 h-100">

                    <div class="o_org_chart_entry o_treeEntry position-relative d-flex py-2 overflow-visible"
                         style="width : 80%; height : 100%;">

                        <span class="o_media_object flex-shrink-0 rounded me-1"
                              t-att-style='"background-image:url(\"/web/image/res.partner/" + child.id +
                              "/avatar_1024/?unique=" + child.write_date + "\")"'/>

                        <a href="#" class="o_employee_redirect btn btn-link"
                           t-on-click.prevent="() => this._onEmployeeRedirect(child.id)">
                            <b class="flex-grow-1 fw-large"><t t-esc="child.name"/></b>
                        </a>

                        <small class="text-muted" t-attf-class="opacity-100-hover">Child</small>

                    </div>
                <div class="w-20">

                    <button class="btn btn-secondary btn-sm d-flex ms-2 rounded-pill"
                            t-on-click="(event) => this._onOpenPopover(event, child)">

                            <span class="badge px-0">View</span>

                    </button>


                    </div>
                </div>
            </t>

        </h3>

    </div>
</t>


    <t t-name="customer_org_chart.contact_orgchart_emp_popover_">
    <div class="o_org_chart_popup" role="tooltip">
        <div class="tooltip-arrow"/>
        <h3 class="popover-header">
            <div class="d-flex align-items-center">
                <span class="o_media_object flex-shrink-0 rounded me-1"
                      t-att-style='"background-image:url(\"/web/image/res.partner/" +
                      this.props.child.id + "/avatar_1024/?unique=" + this.props.child.write_date + "\")"'/>
                <b class="flex-grow-1 fw-medium"><t t-esc="this.props.child.name"/></b>
                <a href="#" class="o_employee_redirect btn btn-link" t-att-data-employee-id="this.props.child.id"
                   t-on-click.prevent="() => this._onEmployeeRedirect(this.props.child.id)">
                    <i class="fa fa-user" role="img" aria-label='View employee' title="View employee"/>
                </a>
            </div>
        </h3>

    </div>
</t>


</templates>
