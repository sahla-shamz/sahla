<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">




<t t-name="customer_org_chart.contact_org_chart">

    <div class="o_org_chart_group_up position-relative">

            <t t-call="customer_org_chart.contact_orgchart_emp_popover">
            </t>

    </div>

</t>

<t t-name="customer_org_chart.contact_orgchart_emp_popover">
    <div class="o_org_chart_popup" role="tooltip">
        <div class="tooltip-arrow"/>
        <h3 class="popover-header">
            <div class="d-flex align-items-center">

                <span class="o_media_object flex-shrink-0 rounded me-1" t-att-style='"background-image:url(\"/web/image/res.partner/" + this.managers.id + "/avatar_1024/?unique=" + this.managers.write_date + "\")"'/>
                <a href="#" class="o_employee_redirect btn btn-link" t-on-click.prevent="() => this._onEmployeeRedirect(this.managers.id)">
                    <h4 class="flex-grow-1 fw-large"><t t-esc="this.managers.name"/></h4>
                </a>
                <small class="o_employee_job text-muted" t-attf-class="opacity-100-hover">Parent</small>

            </div>
            <t t-foreach="children" t-as="child" t-key="child_index">
            <div class="o_org_chart_entry o_treeEntry position-relative d-flex py-2 overflow-visible pe-none">
                <span class="o_media_object flex-shrink-0 rounded me-1" t-att-style='"background-image:url(\"/web/image/res.partner/" + child.id + "/avatar_1024/?unique=" + child.write_date + "\")"'/>

                <a href="#" class="o_employee_redirect btn btn-link" t-on-click.prevent="() => this._onEmployeeRedirect(child.id)">
                    <b class="flex-grow-1 fw-large"><t t-esc="child.name"/></b>
                </a>

                <small class="text-muted" t-attf-class="opacity-100-hover">Child</small>

            </div>
            </t>

        </h3>

    </div>
</t>

</templates>
