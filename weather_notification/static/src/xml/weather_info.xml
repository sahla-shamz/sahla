<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <t t-name="systray_icon" owl="1">
<Dropdown>
        <button>
            <div t-on-click="weather_info">
                <i class="fa fa-cloud" style="cursor: pointer; font-size: 18px;"/>
            </div>
        </button>

    <t t-set-slot="content">
           <DropdownItem>
               <div style="margin: 10px;">
               <div style="height : 230px; width : 350px; display: flex; ">
                   <div style="height : 150px; width : 50%;">
                        <p><t t-esc="this.state.tdate"/></p>
                        <p>Near <t t-esc="this.state.value.name"/>, <t t-esc="this.state.value.sys.country"/>. </p>
                        <h1><t t-esc="this.state.value.main.temp"/>° <t t-esc="this.state.value.weather[0].main"/> </h1>
                        <h3>feels like <t t-esc="this.state.value.main.feels_like"/>°</h3>
                        <p><t t-esc="this.state.value.weather[0].description"/> In <t t-esc="this.state.value.name"/></p>
                        <p>Humidity : <t t-esc="this.state.value.main.humidity"/>% ,
                            Cloudiness : <t t-esc="this.state.value.clouds.all"/>%,
                            Wind : <t t-esc="this.state.value.wind.speed"/>m/s </p>
                        <p>Sunrise : <t t-esc="this.state.sunrise"/>,
                           Sunset : <t t-esc="this.state.sunset"/> </p>
                   </div>
                   <div style="height : 150px ; width : 50%;">
                        <img t-attf-src="{{this.state.img}}" height="180px" width="180px"/>
                   </div>

               </div>
               <div style="height : 50px; width : 380px;">
                   <h6>Last Updated on <br/></h6>
                   <p><t t-esc="this.state.date"/></p>
               </div>
               </div>

           </DropdownItem>

        </t>
</Dropdown>
        </t>

</templates>