<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <t t-name="salesperson_filter.CrmListTemplate" t-inherit="web.ListRenderer" t-inherit-mode="primary">
        <xpath expr="//table" position="before">
            <div style="height : 70px ; width : 250px; margin : 20px;">
                <h4>Sales Person:</h4>
                <select t-model="state.salesperson.id" t-on-change="onChange">
                    <option value="select">Select</option>
                    <t t-foreach="this.state.salesperson" t-as="salesperson" t-key="salesperson_index">
                        <option t-att-value="salesperson.id" t-esc="salesperson.name"/>

                    </t>

                </select>
            </div>
        </xpath>
    </t>

</templates>
