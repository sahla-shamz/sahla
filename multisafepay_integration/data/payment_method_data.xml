<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="payment_method_multisafepay" model="payment.method">
        <field name="name">MultiSafe Pay</field>
        <field name="code">multisafe</field>
        <field name="sequence">1009</field>
        <field name="active">True</field>
        <field name="image" type="base64" file="multisafepay_integration/static/img/multisafe_pay.png"/>
        <field name="support_tokenization">True</field>
        <field name="support_express_checkout">False</field>
        <field name="support_manual_capture">partial</field>
        <field name="support_refund">partial</field>
        <field name="supported_country_ids" eval="[Command.clear()]"/>
        <field name="supported_currency_ids" eval="[Command.clear()]"/>

    </record>
    </data>
</odoo>