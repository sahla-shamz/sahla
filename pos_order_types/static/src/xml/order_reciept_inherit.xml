<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_order_types.OrderReceipt" t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension">
        <xpath expr="//ReceiptHeader" position="after">
            <center>Order Type : <t t-if="order.pos_order_type_id" t-esc="order.pos_order_type_id.name"/>
            <t t-else="">None</t></center>
            <t t-log="order"/>
        </xpath>
    </t>
</templates>