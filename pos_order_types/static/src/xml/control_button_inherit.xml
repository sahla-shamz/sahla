<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_order_types.ControlButtons" t-inherit="point_of_sale.ControlButtons" t-inherit-mode="extension">
        <xpath expr="//SelectPartnerButton" position="before">
            <button class="btn btn-secondary btn-lg more-btn"
                    t-if="this.pos.config.is_enable_order_type" t-on-click="onClickOrderType">
                <t t-if="this.currentOrder.pos_order_type_id"><t t-esc="this.currentOrder.pos_order_type_id.name"/>
                </t>

                <t t-else="">Order Types</t>
            </button>
        </xpath>
    </t>
</templates>
