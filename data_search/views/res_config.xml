<?xml version="1.0" encoding="UTF-8" ?>
<odoo>


    <record id="view_res_config_data_search" model="ir.ui.view">
        <field name="name">res.config.data.search.form.inherit</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='languages_setting']" position="inside">
                <button icon="oi-arrow-right" name="%(action_data_search_wizard)d"
                        type="action" string="Data Search" class="btn-link"/>
            </xpath>
        </field>
    </record>


</odoo>