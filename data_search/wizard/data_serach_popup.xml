<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <record id="action_data_search_wizard" model="ir.actions.act_window">
        <field name="name">Data Search</field>
        <field name="res_model">data.search</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>


    <record id="data_search_form_wizard" model="ir.ui.view">
        <field name="name">data.search.form.wizard</field>
        <field name="model">data.search</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="model_id"/>
                    <field name="field_id" domain="[('model_id', '=', model_id), ('id', 'not in', field_ids)]" />
                    <field name="field_ids" invisible="1"/>
                    <field name="one2many_field_id" domain="[('model_id', '=', one2many_model)]"
                           invisible="not is_one2many or not field_id" />
                    <field name="search_rec" invisible="not field_id or is_date or is_boolean or is_selection"/>
                    <field name="search_date" invisible="not field_id or not is_date"/>
                    <field name="search_boolean" invisible="not field_id or not is_boolean"/>
                    <field name="selection_ids" domain="[('field_id', '=', field_id)]" invisible="not field_id or not is_selection"/>
                </group>
                <footer>
                    <button string="search" class="oe_highlight" type="object" name="action_search"/>
                </footer>

            </form>
        </field>
    </record>


</odoo>
