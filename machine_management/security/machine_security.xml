<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="machine_company_rule" model="ir.rule">
            <field name="name">Machine Company Rule</field>
            <field name="model_id" ref="model_machine_management_machine"/>
            <field name="domain_force">['|',('company_id' ,'in', company_ids), ('company_id', '=', False)]</field>
        </record>

        <record id="machine_transfer_company_rule" model="ir.rule">
            <field name="name">Machine transfer Company Rule</field>
            <field name="model_id" ref="model_machine_transfer"/>
            <field name="domain_force">['|',('company_id' ,'in', company_ids), ('company_id', '=', False)]</field>
        </record>

        <record id="machine_service_company_rule" model="ir.rule">
            <field name="name">Machine Service Company Rule</field>
            <field name="model_id" ref="model_machine_service"/>
            <field name="domain_force">['|',('company_id' ,'in', company_ids), ('company_id', '=', False)]</field>
        </record>


        <record id="res_groups_privilege_machine" model="res.groups.privilege">
            <field name="name">Machine Management</field>
            <field name="category_id" ref="base.module_category_sales"/>
        </record>


        <record id="machine_techperson" model="res.groups">
            <field name="name">Techperson</field>
            <field name="privilege_id" ref="machine_management.res_groups_privilege_machine"/>
            <field name="sequence">10</field>
        </record>

        <record id="res_user_group_machine_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="privilege_id" ref="machine_management.res_groups_privilege_machine"/>
            <field name="sequence">15</field>
        </record>


        <record id="machine_management_techperson_rule" model="ir.rule">
           <field name="name">can only view their case only</field>
           <field name="model_id" ref="model_machine_service"/>
           <field name="domain_force">[('tech_person_ids', '=', user)]</field>
           <field name="groups" eval="[Command.link(ref('machine_techperson'))]"/>
           <field name="perm_create" eval="True"/>
           <field name="perm_read" eval="True"/>
           <field name="perm_write" eval="True"/>
           <field name="perm_unlink" eval="True"/>
        </record>

    </data>
</odoo>