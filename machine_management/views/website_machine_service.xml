    <template id="machine_service_website_form_template" name="Machine Service Website Form">
        <t name="Machine Service Page" t-name="machine_management.machine_service">
            <t t-call="website.layout">
                <div id="wrap" class="oe_structure oe_empty">
                    <section class="s_title parallax s_parallax_is_fixed bg-black-50 pt24 pb24" data-vcss="001" data-snippet="s_title" data-scroll-background-ratio="1">
                    <span class="s_parallax_bg oe_img_bg" style="background-image: url('/web/image/website.s_parallax_default_image'); background-position: 50% 0;"/>
                    <div class="o_we_bg_filter bg-black-50"/>
                    <div class="container">
                        <h1>Create Machine Service</h1>
                    </div>
                    </section>
                    <section class="s_text_block pt40 pb40 o_colored_level" style="background-color: white;">
                        <div class="container s_allow_columns">
                            <div class="row">
                                <div class="col-lg-7 mt-4 mt-lg-0">
                                    <p class="lead">
                                        Contact us about anything related to our company or services.<br/>
                                        We'll do our best to get back to you as soon as possible.
                                    </p>
                                    <div class="container">
                                        <form action="/website/machine_service/create" method="post" style="padding : 60px;">
                                            <div class="s_website_form_rows row s_col_no_bgcolor">
                                                <div class="mb-3 col-lg-6 s_website_form_field s_website_form_custom s_website_form_required" data-type="char" data-name="Field">
                                                    <div style="height: 600px; width: 600px; ">
                                                         <label class="s_website_form_label" style="width: 200px; padding : 20px;" for="contact6">
                                                            <span class="s_website_form_label_content">Machine Name:</span>
                                                            <span class="s_website_form_mark"> *</span>
                                                        </label>
                                                        <select name="machine" class="form-control s_website_form_input">
                                                           <option value="">Select Machine</option>
                                                           <t t-foreach="machines" t-as="machine">
                                                               <option t-att-value="machine.id">
                                                                   <t t-esc="machine.name"/>
                                                               </option>
                                                           </t>
                                                        </select>

                                                        <label class="s_website_form_label" style="width: 200px;  padding : 20px;" for="contact6">
                                                            <span class="s_website_form_label_content">Customer Name:</span>
                                                            <span class="s_website_form_mark"> *</span>
                                                        </label>
                                                        <select name="customer" class="form-control s_website_form_input">
                                                           <option value="">Select Customer</option>
                                                           <t t-foreach="customers" t-as="customer">
                                                               <option t-att-value="customer.id">
                                                                   <t t-esc="customer.name"/>
                                                               </option>
                                                           </t>
                                                        </select>

                                                        <label class="s_website_form_label" style="width: 200px;  padding : 20px;" for="contact6">
                                                            <span class="s_website_form_label_content">Date:</span>
                                                            <span class="s_website_form_mark"> *</span>
                                                        </label>
                                                        <input type="date" name="date" class="form-control s_website_form_input" required=""/>


                                                        <div class="mb-3 col-12 s_website_form_field s_website_form_custom s_website_form_required" data-type="text" data-name="Field">
                                                            <label class="s_website_form_label" style="width: 200px;  padding : 20px;" for="contact6">
                                                                <span class="s_website_form_label_content">Description</span>
                                                                <span class="s_website_form_mark"> *</span>
                                                            </label>
                                                            <textarea id="contact6" class="form-control s_website_form_input" name="description" required="" rows="5"></textarea>
                                                        </div>

                                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                                                        <div class="mb-0 py-2 col-12 s_website_form_submit s_website_form_no_submit_label text-end" data-name="Submit Button">
                                                            <div style="width: 200px;" class="s_website_form_label"/>
                                                            <a href="/create_customer" role="button" class="btn btn-primary s_website_form_send">Create Customer</a>
                                                            <button class="btn btn-primary btn-block rounded-3 py-2">Submit</button>
                                                        </div>
                                                        </div>
                                                    </div>
                                                </div>
                                        </form>
                                    </div>
                                </div>
                                <div class="col-lg-4 offset-lg-1 mt-4 mt-lg-0">
                                    <h5>My Company</h5>
                                    <ul class="list-unstyled mb-0 ps-2">
                                        <li><i class="fa fa-map-marker fa-fw me-2"/><span class="o_force_ltr">3575 Fake Buena Vista Avenue</span></li>
                                        <li><i class="fa fa-phone fa-fw me-2"/><span class="o_force_ltr">+1 555-555-5556</span></li>
                                        <li><i class="fa fa-1x fa-fw fa-envelope me-2"/><span>info@yourcompany.example.com</span></li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </section>
                </div>
            </t>
        </t>
    </template>



    <template id="machine_service_success_template" name="Machine Service Created">
        <t t-call="website.layout">
            <section class="d-flex align-items-center justify-content-center vh-100" style="background-color: #f8f9fa;">
                <div class="text-center">
                    <h3 class="text-success mb-3">Machine Service Created Successfully!</h3>
                    <a href="/machine_service" class="btn btn-primary rounded-3">Add Another Machine Service</a>
                </div>
            </section>
        </t>
    </template>

    <record id="menu_machine_service_page" model="website.menu">
        <field name="name">Machine Service Page</field>
        <field name="url">/machine_service</field>
        <field name="parent_id" ref="website.main_menu"/>
        <field name="sequence" type="int">60</field>
    </record>


</odoo>