<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="machine_template_highlight" name="Machine Highlight">
        <section id="machine_carousel">
            <div class="container">

                <div id="carousel_machine">
                    <div class="alert alert-info">

                    <h4>Your Category Highlight Tab snippet will be displayed here...
                        Please save to view the snippet. haha
                    </h4>
               </div>
                </div>

            </div>
        </section>
    </template>

    <template id="machine_highlight_snippet" inherit_id="website.snippets"
                  name="Machine Highlight Snippet">
        <xpath expr="//snippets[@id='snippet_groups']" position="inside">
            <t t-snippet="machine_management.machine_template_highlight"
               />
        </xpath>

      <xpath expr="//snippets[@id='snippet_structure']" position="inside">
           <t t-snippet="machine_management.machine_template_highlight"/>
       </xpath>
    </template>
</odoo>