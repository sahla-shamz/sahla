<?xml version="1.0" encoding="UTF-8" ?>
<odoo>


    <template id="portal_products_template" inherit_id="portal.portal_my_home">
        <xpath expr="//div[@id='portal_common_category']" position="inside">

            <t t-call="portal.portal_docs_entry">
                <t t-set="icon" t-value="'/website_product_visibility/static/src/img/portal-products.svg'"/>
                <t t-set="title">Products</t>
                <t t-set="text">View Your Products</t>
                <t t-set="url" t-value="'/my/products'"/>
                <t t-set="config_card" t-value="True"/>
            </t>
        </xpath>
    </template>


</odoo>